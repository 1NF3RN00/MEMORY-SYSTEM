generator client {

  provider        = "prisma-client-js"

  previewFeatures = ["postgresqlExtensions"]

  binaryTargets   = ["native", "rhel-openssl-3.0.x"]

}



datasource db {

  provider   = "postgresql"

  url        = env("DATABASE_URL")

  directUrl  = env("DIRECT_URL")

  extensions = [pgvector(map: "vector"), pgcrypto]

}



/// Top-level tenancy — agencies own platforms.

model Agency {

  id        String   @id

  name      String

  slug      String   @unique

  archived  Boolean  @default(false)

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")



  platforms     Platform[]

  platformUsers PlatformUser[] @relation("AgencyUsers")



  @@map("agencies")

}



/// Platform — workspaces belong to a platform.

model Platform {

  id        String   @id

  agencyId  String   @map("agency_id")

  name      String

  slug      String   @unique

  archived  Boolean  @default(false)

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")



  agency        Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  workspaces    Workspace[]

  platformUsers PlatformUser[] @relation("PlatformUsers")



  @@index([agencyId])

  @@map("platforms")

}



/// Tenant workspace — configuration and isolation boundary (ULID).

model Workspace {

  id          String   @id

  platformId  String   @map("platform_id")

  name        String

  slug        String   @unique

  ownerUserId String?  @map("owner_user_id")

  plan        String   @default("alpha")

  archived    Boolean  @default(false)

  config      Json     @default("{}")

  createdAt   DateTime @default(now()) @map("created_at")

  updatedAt   DateTime @updatedAt @map("updated_at")



  platform              Platform            @relation(fields: [platformId], references: [id], onDelete: Restrict)

  memberships           WorkspaceMembership[]

  apiKeys               ApiKey[]

  memories              Memory[]

  retrievalOperations   RetrievalOperation[]

  compressionOperations CompressionOperation[]

  contextRenderOperations ContextRenderOperation[]

  memoryRelationships   MemoryRelationship[]

  compressionArtifacts  CompressionArtifact[]

  snapshots             Snapshot[]

  replaySnapshots       ReplaySnapshot[]

  retrievalPlans        RetrievalPlan[]

  eventLogs             EventLog[]

  ingestionJobs         IngestionJob[]

  ingestionTraces       IngestionTrace[]

  sourceTruths          SourceTruth[]

  domains               Domain[]

  globalFacts           GlobalFact[]

  installedPackages     InstalledPackage[]

  operationalObjects    OperationalObject[]

  workflows             Workflow[]

  workflowRuns          WorkflowRun[]

  workflowOutputs       WorkflowOutput[]



  @@index([platformId])

  @@map("workspaces")

}



/// Append-only memory record. IDs are ULIDs (application-assigned).

model Memory {

  id                   String    @id

  workspaceId          String    @map("workspace_id")

  lineageId            String    @map("lineage_id")

  version              Int       @default(1)

  parentMemoryId       String?   @map("parent_memory_id")

  memoryType           String    @default("semantic") @map("memory_type")

  persistenceMode      String    @default("persistent") @map("persistence_mode")

  sourceType           String    @map("source_type")

  title                String    @default("")

  content              String

  normalizedContent    String    @map("normalized_content")

  summary              String?

  ingestionStatus      String    @default("pending") @map("ingestion_status")

  ingestionTraceId     String    @map("ingestion_trace_id")

  normalizationTraceId String    @map("normalization_trace_id")

  embeddingVersion     String    @default("openai-text-embedding-3-small-v1") @map("embedding_version")

  normalizationVersion String    @default("deterministic-v1") @map("normalization_version")

  metadata             Json      @default("{}")

  scoring              Json      @default("{}")

  lineage              Json      @default("{}")

  observability        Json      @default("{}")

  sourceWorkflowRunId  String?   @map("source_workflow_run_id")

  archived             Boolean   @default(false)

  retrievalEligible    Boolean   @default(true) @map("retrieval_eligible")

  expiresAt            DateTime? @map("expires_at")

  archivedAt           DateTime? @map("archived_at")

  createdAt            DateTime  @default(now()) @map("created_at")

  updatedAt            DateTime  @updatedAt @map("updated_at")



  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  chunks    MemoryChunk[]

  relationshipsAsSource MemoryRelationship[] @relation("RelationshipSource")

  relationshipsAsTarget MemoryRelationship[] @relation("RelationshipTarget")



  @@unique([lineageId, version])

  @@index([workspaceId])

  @@index([lineageId])

  @@index([ingestionTraceId])

  @@map("memories")

}



/// Chunks belong to a Memory — IDs are ULIDs.

model MemoryChunk {

  id              String                       @id

  memoryId        String                       @map("memory_id")

  sequence        Int

  content         String

  tokenCount      Int                          @default(0) @map("token_count")

  embeddingStatus String                       @default("pending") @map("embedding_status")

  metadata        Json                         @default("{}")

  observability   Json                         @default("{}")

  embedding       Unsupported("vector(1536)")?

  createdAt       DateTime                     @default(now()) @map("created_at")



  memory Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)



  @@unique([memoryId, sequence])

  @@index([memoryId])

  @@map("memory_chunks")

}



/// Async ingestion job queue — IDs are ULIDs.

model IngestionJob {

  id                String    @id

  workspaceId       String    @map("workspace_id")

  traceId           String    @map("trace_id")

  status            String    @default("pending")

  sourceType        String    @map("source_type")

  persistenceMode   String    @default("persistent") @map("persistence_mode")

  memoryType        String    @default("semantic") @map("memory_type")

  inputPayload      Json      @map("input_payload")

  memoryId          String?   @map("memory_id")

  lineageId         String?   @map("lineage_id")

  attemptCount      Int       @default(0) @map("attempt_count")

  maxAttempts       Int       @default(3) @map("max_attempts")

  lastError         String?   @map("last_error")

  useLlmStructuring Boolean   @default(false) @map("use_llm_structuring")

  createdAt         DateTime  @default(now()) @map("created_at")

  updatedAt         DateTime  @updatedAt @map("updated_at")

  startedAt         DateTime? @map("started_at")

  completedAt       DateTime? @map("completed_at")



  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)



  @@index([status])

  @@index([traceId])

  @@index([workspaceId])

  @@map("ingestion_jobs")

}



/// Replayable ingestion trace — traceId is the primary observability ULID.

model IngestionTrace {

  id                 String   @id

  workspaceId        String   @map("workspace_id")

  traceId            String   @unique @map("trace_id")

  status             String   @default("pending")

  sourceType         String   @map("source_type")

  persistenceMode    String   @map("persistence_mode")

  memoryId           String?  @map("memory_id")

  stages             Json     @default("[]")

  normalizationTrace Json?    @map("normalization_trace")

  createdAt          DateTime @default(now()) @map("created_at")

  updatedAt          DateTime @updatedAt @map("updated_at")



  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)



  @@index([workspaceId])

  @@index([memoryId])

  @@map("ingestion_traces")

}



/// Source truth layer — IDs are ULIDs.

model SourceTruth {

  id                           String   @id

  workspaceId                  String   @map("workspace_id")

  traceId                      String   @map("trace_id")

  memoryId                     String?  @map("memory_id")

  rawSource                    String   @map("raw_source")

  crawlerOutput                Json?    @map("crawler_output")

  normalizationTransformations Json     @default("[]") @map("normalization_transformations")

  createdAt                    DateTime @default(now()) @map("created_at")



  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)



  @@index([traceId])

  @@index([memoryId])

  @@map("source_truths")

}



/// Observability record for retrieval operations — scaffolding only.

model RetrievalOperation {

  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  workspaceId String    @map("workspace_id")

  traceId     String    @map("trace_id")

  query       String

  status      String    @default("pending")

  result      Json?

  createdAt   DateTime  @default(now()) @map("created_at")

  completedAt DateTime? @map("completed_at")



  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)



  @@index([workspaceId])

  @@index([traceId])

  @@map("retrieval_operations")

}



/// Sprint 6 retrieval planning artifacts — deterministic preprocessing plans.

model RetrievalPlan {

  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  planId        String   @unique @map("plan_id")

  workspaceId   String   @map("workspace_id")

  query         String

  retrievalMode String   @map("retrieval_mode")

  status        String   @default("completed")

  plan          Json

  replayInput   Json     @map("replay_input")

  stages        Json     @default("[]")

  createdAt     DateTime @default(now()) @map("created_at")



  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)



  @@index([workspaceId])

  @@index([planId])

  @@map("retrieval_plans")

}



/// Observability record for compression operations — Sprint 3.

model CompressionOperation {

  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  workspaceId String    @map("workspace_id")

  traceId     String    @map("trace_id")

  retrievalTraceId String @map("retrieval_trace_id")

  status      String    @default("pending")

  result      Json?

  createdAt   DateTime  @default(now()) @map("created_at")

  completedAt DateTime? @map("completed_at")



  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)



  @@index([workspaceId])

  @@index([traceId])

  @@index([retrievalTraceId])

  @@map("compression_operations")

}



/// Context delivery + rendering operations — transforms middleware state into LLM inference context.

model ContextRenderOperation {

  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  workspaceId        String    @map("workspace_id")

  deliveryId         String    @map("delivery_id")

  retrievalTraceId   String    @map("retrieval_trace_id")

  compressionTraceId String?   @map("compression_trace_id")

  status             String    @default("pending")

  result             Json?

  createdAt          DateTime  @default(now()) @map("created_at")

  completedAt        DateTime? @map("completed_at")



  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)



  @@index([workspaceId])

  @@index([deliveryId])

  @@index([retrievalTraceId])

  @@index([compressionTraceId])

  @@map("context_render_operations")

}



/// Lightweight memory relationship storage — adjacency and co-retrieval hints.

model MemoryRelationship {

  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  workspaceId      String   @map("workspace_id")

  sourceMemoryId   String   @map("source_memory_id")

  targetMemoryId   String   @map("target_memory_id")

  relationshipType String   @map("relationship_type")

  weight           Float    @default(0.5)

  metadata         Json     @default("{}")

  compressionTraceId String? @map("compression_trace_id")

  createdAt        DateTime @default(now()) @map("created_at")

  updatedAt        DateTime @updatedAt @map("updated_at")



  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  sourceMemory Memory    @relation("RelationshipSource", fields: [sourceMemoryId], references: [id], onDelete: Cascade)

  targetMemory Memory    @relation("RelationshipTarget", fields: [targetMemoryId], references: [id], onDelete: Cascade)



  @@unique([workspaceId, sourceMemoryId, targetMemoryId, relationshipType])

  @@index([workspaceId])

  @@index([sourceMemoryId])

  @@index([targetMemoryId])

  @@index([compressionTraceId])

  @@map("memory_relationships")

}



/// Stored compression output — artifact record only in Sprint 0.

model CompressionArtifact {

  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  workspaceId String   @map("workspace_id")

  sourceType  String   @map("source_type")

  sourceId    String   @map("source_id")

  content     String

  metadata    Json     @default("{}")

  createdAt   DateTime @default(now()) @map("created_at")



  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)



  @@index([workspaceId])

  @@index([sourceType, sourceId])

  @@map("compression_artifacts")

}



/// Full replay snapshots for deterministic historian replay — Sprint 5.

model ReplaySnapshot {

  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  replayId         String   @unique @map("replay_id")

  retrievalTraceId String   @map("retrieval_trace_id")

  workspaceId      String   @map("workspace_id")

  integrityHash    String   @map("integrity_hash")

  payload          Json

  retentionMode    String   @default("operational") @map("retention_mode")

  archivedAt       DateTime? @map("archived_at")

  createdAt        DateTime @default(now()) @map("created_at")



  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)



  @@index([workspaceId])

  @@index([retrievalTraceId])

  @@index([retentionMode])

  @@index([createdAt])

  @@map("replay_snapshots")

}



/// Point-in-time snapshots for replay and observability.

model Snapshot {

  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  workspaceId  String   @map("workspace_id")

  snapshotType String   @map("snapshot_type")

  payload      Json

  createdAt    DateTime @default(now()) @map("created_at")



  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)



  @@index([workspaceId])

  @@index([snapshotType])

  @@map("snapshots")

}



/// Append-only structured event log.

model EventLog {

  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  workspaceId String?  @map("workspace_id")

  eventType   String   @map("event_type")

  traceId     String   @map("trace_id")

  severity    String   @default("info")

  payload     Json

  timestamp   DateTime @default(now())



  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)



  @@index([traceId])

  @@index([eventType])

  @@index([timestamp])

  @@map("event_logs")

}



/// Infrastructure access request — invite-only onboarding queue.

model AccessRequest {

  id         String    @id @map("request_id")

  email      String

  company    String?

  useCase    String?   @map("use_case")

  note       String?

  status     String    @default("pending")

  createdAt  DateTime  @default(now()) @map("created_at")

  reviewedAt DateTime? @map("reviewed_at")

  reviewedBy String?   @map("reviewed_by")

  provisionedWorkspaceId String? @map("provisioned_workspace_id")



  @@index([email])

  @@index([status])

  @@map("access_requests")

}



/// Platform user linked to Supabase Auth.

model PlatformUser {

  id                String   @id

  supabaseUserId    String   @unique @map("supabase_user_id")

  email             String   @unique

  isPlatformAdmin   Boolean  @default(false) @map("is_platform_admin")

  isMiddlewareAdmin Boolean  @default(false) @map("is_middleware_admin")

  agencyId          String?  @map("agency_id")

  platformId        String?  @map("platform_id")

  createdAt         DateTime @default(now()) @map("created_at")



  agency      Agency?  @relation("AgencyUsers", fields: [agencyId], references: [id], onDelete: SetNull)

  platform    Platform? @relation("PlatformUsers", fields: [platformId], references: [id], onDelete: SetNull)

  memberships WorkspaceMembership[]



  @@index([agencyId])

  @@index([platformId])

  @@map("platform_users")

}



/// Workspace membership — role-based operational access.

model WorkspaceMembership {

  id              String   @id

  workspaceId     String   @map("workspace_id")

  userId          String   @map("user_id")

  role            String

  operationalRole String?  @map("operational_role")

  createdAt       DateTime @default(now()) @map("created_at")



  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  user      PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@unique([workspaceId, userId])

  @@index([userId])

  @@map("workspace_memberships")

}



/// Middleware API key — hashed at rest, never stored raw.

model ApiKey {

  id          String    @id

  workspaceId String    @map("workspace_id")

  hashedKey   String    @map("hashed_key")

  keyPrefix   String    @map("key_prefix")

  name        String

  permissions Json      @default("[]")

  createdAt   DateTime  @default(now()) @map("created_at")

  lastUsedAt  DateTime? @map("last_used_at")

  revoked     Boolean   @default(false)



  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)



  @@index([workspaceId])

  @@index([keyPrefix])

  @@map("api_keys")

}



/// Security audit events — auth failures, permission denials, revoked key usage.

model SecurityEvent {

  id          String   @id

  workspaceId String?  @map("workspace_id")

  eventType   String   @map("event_type")

  severity    String   @default("warn")

  actorUserId String?  @map("actor_user_id")

  metadata    Json     @default("{}")

  createdAt   DateTime @default(now()) @map("created_at")



  @@index([workspaceId])

  @@index([eventType])

  @@index([createdAt])

  @@map("security_events")

}



/// Domain Engine — task-scoped operational intelligence boundary.

model Domain {

  id                      String    @id

  workspaceId             String    @map("workspace_id")

  domainKey               String    @map("domain_key")

  name                    String

  description             String?

  status                  String    @default("active")

  metadataFilters         Json      @default("[]") @map("metadata_filters")

  observationFilters      Json      @default("[]") @map("observation_filters")

  relationshipConstraints Json      @default("{}") @map("relationship_constraints")

  sourcePackageId         String?   @map("source_package_id")

  archivedAt              DateTime? @map("archived_at")

  createdAt               DateTime  @default(now()) @map("created_at")

  updatedAt               DateTime  @updatedAt @map("updated_at")



  workspace      Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  retrievalRules DomainRetrievalRule[]

  facts          DomainFact[]

  instructions   DomainInstruction[]



  @@unique([workspaceId, domainKey])

  @@index([workspaceId])

  @@map("domains")

}



model DomainRetrievalRule {

  id        String @id

  domainId  String @map("domain_id")

  name      String

  config    Json   @default("{}")

  sortOrder Int    @default(0) @map("sort_order")



  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)



  @@index([domainId])

  @@map("domain_retrieval_rules")

}



model GlobalFact {

  id                    String    @id

  workspaceId           String    @map("workspace_id")

  key                   String

  title                 String

  content               String

  priority              Int       @default(0)

  status                String    @default("active")

  appliesToMetadataKeys Json      @default("[]") @map("applies_to_metadata_keys")

  sourcePackageId       String?   @map("source_package_id")

  sourceWorkflowRunId   String?   @map("source_workflow_run_id")

  version               Int       @default(1)

  archivedAt            DateTime? @map("archived_at")

  createdAt             DateTime  @default(now()) @map("created_at")

  updatedAt             DateTime  @updatedAt @map("updated_at")



  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)



  @@unique([workspaceId, key])

  @@index([workspaceId])

  @@map("global_facts")

}



model DomainFact {

  id                    String    @id

  workspaceId           String    @map("workspace_id")

  domainId              String    @map("domain_id")

  key                   String

  title                 String

  content               String

  priority              Int       @default(0)

  status                String    @default("active")

  appliesToMetadataKeys Json      @default("[]") @map("applies_to_metadata_keys")

  sourcePackageId       String?   @map("source_package_id")

  sourceWorkflowRunId   String?   @map("source_workflow_run_id")

  version               Int       @default(1)

  archivedAt            DateTime? @map("archived_at")

  createdAt             DateTime  @default(now()) @map("created_at")

  updatedAt             DateTime  @updatedAt @map("updated_at")



  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)



  @@unique([domainId, key])

  @@index([workspaceId])

  @@map("domain_facts")

}



model DomainInstruction {

  id              String    @id

  workspaceId     String    @map("workspace_id")

  domainId        String    @map("domain_id")

  actionKey       String    @map("action_key")

  title           String

  content         String

  status          String    @default("active")

  version         Int       @default(1)

  isActive        Boolean   @default(true) @map("is_active")

  sourcePackageId String?   @map("source_package_id")

  archivedAt      DateTime? @map("archived_at")

  createdAt       DateTime  @default(now()) @map("created_at")

  updatedAt       DateTime  @updatedAt @map("updated_at")



  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)



  @@index([domainId, actionKey])

  @@index([workspaceId])

  @@map("domain_instructions")

}



model PackageDefinition {

  id          String   @id

  packageKey  String   @unique @map("package_key")

  name        String

  version     String

  description String?

  manifest    Json

  published   Boolean  @default(false)

  createdAt   DateTime @default(now()) @map("created_at")

  updatedAt   DateTime @updatedAt @map("updated_at")



  installations InstalledPackage[]



  @@map("package_definitions")

}



model InstalledPackage {

  id                  String    @id

  workspaceId         String    @map("workspace_id")

  packageDefinitionId String    @map("package_definition_id")

  packageKey          String    @map("package_key")

  installedVersion    String    @map("installed_version")

  snapshotVersion     String    @map("snapshot_version")

  status              String    @default("active")

  manifestSnapshot    Json      @map("manifest_snapshot")

  snapshotHistory     Json      @default("[]") @map("snapshot_history")

  installedByUserId   String?   @map("installed_by_user_id")

  installedAt         DateTime  @default(now()) @map("installed_at")

  archivedAt          DateTime? @map("archived_at")



  workspace         Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  packageDefinition PackageDefinition @relation(fields: [packageDefinitionId], references: [id], onDelete: Restrict)



  @@index([workspaceId])

  @@map("installed_packages")

}



model OperationalObject {

  id          String    @id

  workspaceId String    @map("workspace_id")

  objectType  String    @map("object_type")

  name        String

  status      String

  metadata    Json      @default("{}")

  rowStatus   String    @default("active") @map("row_status")

  archivedAt  DateTime? @map("archived_at")

  createdAt   DateTime  @default(now()) @map("created_at")

  updatedAt   DateTime  @updatedAt @map("updated_at")



  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)



  @@index([workspaceId, objectType])

  @@index([workspaceId, status])

  @@map("operational_objects")

}



model Workflow {

  id                String    @id

  workspaceId       String    @map("workspace_id")

  workflowKey       String?   @map("workflow_key")

  name              String

  description       String    @default("")

  analysisSpecKey   String?   @map("analysis_spec_key")

  domains           Json      @default("[]")

  packages          Json      @default("[]")

  instructionRefs   Json      @default("[]") @map("instruction_refs")

  outputTypes       Json      @default("[]") @map("output_types")

  objectTypeFilters Json      @default("[]") @map("object_type_filters")

  sourcePackageId   String?   @map("source_package_id")

  active            Boolean   @default(true)

  archivedAt        DateTime? @map("archived_at")

  createdAt         DateTime  @default(now()) @map("created_at")

  updatedAt         DateTime  @updatedAt @map("updated_at")



  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  runs      WorkflowRun[]



  @@unique([workspaceId, workflowKey])

  @@index([workspaceId])

  @@index([sourcePackageId])

  @@map("workflows")

}



model WorkflowRun {

  id                 String    @id

  workflowId         String    @map("workflow_id")

  workspaceId        String    @map("workspace_id")

  status             String    @default("pending")

  startedAt          DateTime  @default(now()) @map("started_at")

  completedAt        DateTime? @map("completed_at")

  errorMessage       String?   @map("error_message")

  outputCount        Int       @default(0) @map("output_count")

  generatedFactIds   Json      @default("[]") @map("generated_fact_ids")

  generatedMemoryIds Json      @default("[]") @map("generated_memory_ids")

  generatedObjectIds Json      @default("[]") @map("generated_object_ids")

  executionContext   Json?     @map("execution_context")

  archivedAt         DateTime? @map("archived_at")



  workflow  Workflow         @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  outputs   WorkflowOutput[]



  @@index([workflowId])

  @@index([workspaceId])

  @@map("workflow_runs")

}



model WorkflowOutput {

  id            String   @id

  workflowRunId String   @map("workflow_run_id")

  workspaceId   String   @map("workspace_id")

  outputType    String   @map("output_type")

  title         String

  content       String

  data          Json?

  metadata      Json?

  createdAt     DateTime @default(now()) @map("created_at")



  workflowRun WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)



  @@index([workflowRunId])

  @@index([workspaceId, outputType])

  @@map("workflow_outputs")

}

