# =============================================================================
# Dashboard (Vite) — environment template
# =============================================================================
#
# Setup:
#   cp .env.example .env     (from this directory)
#
# For Vercel: add these same variables in the dashboard project settings.
# See docs/ENVIRONMENT.md
#
# =============================================================================

# Base URL of the memory API (no trailing slash).
# Local dev: leave empty — vite.config.ts proxies API routes to localhost:3000.
# Production: your deployed API origin, e.g. https://api.your-domain.com
VITE_API_URL=

# Default workspace UUID shown on ingest and other pages (optional).
# Create a workspace via POST /workspaces or the API, then paste its id here.
VITE_WORKSPACE_ID=
