# =============================================================================
# semantic-core — environment template
# =============================================================================
#
# Setup:
#   1. Copy this file to the repo root:
#        Windows:  copy .env.example .env
#        macOS:    cp .env.example .env
#   2. Fill in the values below (see docs/ENVIRONMENT.md for Supabase steps).
#   3. Apply schema:  npm run db:migrate:deploy
#
# Dashboard (separate file):  apps/dashboard/.env.example → apps/dashboard/.env
#
# =============================================================================

# --- Application (API + background worker) ---

NODE_ENV=development
LOG_LEVEL=info
API_HOST=0.0.0.0
API_PORT=3000

# --- Database (required) ---
#
# The API talks to Postgres through Prisma. You do NOT need Supabase anon/service
# keys for this codebase — only a Postgres connection string.
#
# LOCAL (Docker Compose — run: npm run docker:up)
DATABASE_URL=postgresql://memory:memory@localhost:5432/memory_middleware?schema=public
DIRECT_URL=postgresql://memory:memory@localhost:5432/memory_middleware?schema=public

# SUPABASE — replace the two lines above when using hosted Postgres:
#
#   DATABASE_URL = Session pooler (port 5432) or Transaction pooler (port 6543)
#                  Use for the running API. Add ?pgbouncer=true on port 6543.
#   DIRECT_URL   = Direct connection (db.<ref>.supabase.co:5432)
#                  Use for migrations (npm run db:migrate:deploy).
#
# Get both from: Supabase Dashboard → your project → Connect → OR Settings → Database
#
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?schema=public
# DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?schema=public

# --- Observability ---

TRACE_HEADER=x-trace-id

# --- OpenAI (optional) ---
#
# Without this key, ingestion embeddings and some compression/historian paths
# degrade gracefully. Get a key at: https://platform.openai.com/api-keys

OPENAI_API_KEY=

# --- Background worker ---

WORKER_POLL_INTERVAL_MS=2000
TEMPORARY_MEMORY_TTL_MS=3600000

# --- Supabase Auth (required for production operational access) ---
#
# Find at: Supabase Dashboard → Project Settings → API
#
# SUPABASE_URL=https://[PROJECT-REF].supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# PASSWORD_SETUP_REDIRECT_URL=https://your-dashboard.vercel.app/access
# PLATFORM_ADMIN_EMAILS=ops@yourcompany.com
#
# With PLATFORM_ADMIN_EMAILS + Supabase keys set, the API auto-provisions the first
# admin (ULID workspace + password email) on startup when no admin exists yet.
#
# Manual bootstrap (optional):
#   npm run bootstrap -- you@email.com
# Note the `--` before the email (npm requires it to pass arguments).
