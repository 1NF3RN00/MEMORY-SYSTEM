# Application
NODE_ENV=development
LOG_LEVEL=info
API_HOST=0.0.0.0
API_PORT=3000

# Database (local development)
DATABASE_URL=postgresql://memory:memory@localhost:5432/memory_middleware?schema=public

# Observability
TRACE_HEADER=x-trace-id

# Ingestion (optional — embeddings degrade gracefully without key)
OPENAI_API_KEY=

# Worker
WORKER_POLL_INTERVAL_MS=2000
TEMPORARY_MEMORY_TTL_MS=3600000
